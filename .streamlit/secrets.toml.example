# Streamlit Cloud Secrets Configuration
# Copy this into your Streamlit Cloud app settings under "Secrets"

# AI Provider Selection
AI_PROVIDER = "gemini"

# Google Gemini Configuration
GOOGLE_API_KEY = "your_actual_google_api_key_here"
GEMINI_PARSING_MODEL = "gemini-2.5-flash"
GEMINI_EXPLANATION_MODEL = "gemini-2.5-flash"

# Optional: Enable/disable AI features
AI_FEATURES_ENABLED = "true"

# Alternative: OpenAI Configuration (if using OpenAI instead)
# AI_PROVIDER = "openai"
# OPENAI_API_KEY = "your_actual_openai_api_key_here"
# OPENAI_PARSING_MODEL = "gpt-4o"
# OPENAI_EXPLANATION_MODEL = "gpt-4o-mini"
